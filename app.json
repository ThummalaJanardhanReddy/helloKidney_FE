{
  "expo": {
    "name": "HelloKidney",
    "slug": "hellokidney",
    "version": "2.2",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon.png",
    "scheme": "hellokidney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ai.hellokidney",
      "versionCode": 66,
      "permissions": ["CAMERA", "INTERNET"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "splash": {
      "image": "./assets/images/Splash_ic.png",
      "resizeMode": "cover",
      "backgroundColor": "#EF3024"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64eaea5e-a9dd-4504-a275-463f838d9ecb"
      }
    }
  }
}
