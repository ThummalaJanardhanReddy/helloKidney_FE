{
  "expo": {
    "name": "HelloKidney",
    "slug": "hellokidney",
    "version": "1.1.44",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon.png",
    "scheme": "hellokidney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.hellokidney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ai.hellokidney",
      "versionCode": 56,
      "permissions": [
        "CAMERA",
        "INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "splash": {
      "image": "./assets/images/Splash_ic.png",
      "resizeMode": "cover",
      "backgroundColor": "#EF3024"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9d0bc0f-ab78-44ec-bbf2-7cb1774caf6d"
      }
    },
    "owner": "janardhanreddy"
  }
}
