{
  "expo": {
    "name": "NephKare",
    "slug": "hellokidney",
    "version": "2.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icons/Nephkare_1024.png",
    "scheme": "hellokidney",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.hellokidney",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "17",
      "version": "2.1.5"
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDUp4kR8HeacIO-hCVhKykSxVDEbmNuhsU"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/adaptive.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ai.hellokidney",
      "versionCode": 73,
      "permissions": [
        "CAMERA",
        "INTERNET"
      ],
      "version": "2.1.1"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "splash": {
      "image": "./assets/images/Splash_ic.png",
      "resizeMode": "cover",
      "backgroundColor": "#EF3024"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9d0bc0f-ab78-44ec-bbf2-7cb1774caf6d"
      }
    },
    "owner": "janardhanreddy"
  }
}
